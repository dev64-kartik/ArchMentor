{
  "name": "archmentor",
  "version": "0.0.0",
  "private": true,
  "description": "AI-powered live system design mentor — workspace root",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10"
