# ArchMentor — local dev environment
# Copy to .env and fill in secrets before running `./scripts/dev.sh`.

# ─── Postgres (shared) ──────────────────────────────────────────────────
# The superuser is pinned to `postgres` because GoTrue's migrations grant
# permissions to a `postgres` role. Renaming this breaks auth boot.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev
POSTGRES_DB=archmentor
POSTGRES_PORT=5432
AUTH_DB=auth
LANGFUSE_DB=langfuse

# ─── Supabase Auth (GoTrue) ─────────────────────────────────────────────
GOTRUE_PORT=9999
GOTRUE_API_EXTERNAL_URL=http://localhost:9999
SITE_URL=http://localhost:3000
# 32+ char random string. Generate: `openssl rand -base64 48`
GOTRUE_JWT_SECRET=replace_with_openssl_rand_base64_48_output_here_xx

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── MinIO ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── LiveKit ────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=devkey
# 32+ char random string. Generate: `openssl rand -base64 48`
LIVEKIT_API_SECRET=replace_with_openssl_rand_base64_48_output_here_xx
LIVEKIT_PORT=7880
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_PORT=7882

# ─── Langfuse ───────────────────────────────────────────────────────────
LANGFUSE_PORT=3001
LANGFUSE_URL=http://localhost:3001
# 32+ char random strings
LANGFUSE_NEXTAUTH_SECRET=replace_with_openssl_rand_base64_48_output_here_xx
LANGFUSE_SALT=replace_with_openssl_rand_base64_48_output_here_xx
LANGFUSE_PUBLIC_KEY=pk-lf-dev-public-key
LANGFUSE_SECRET_KEY=sk-lf-dev-secret-key

# ─── Claude / Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Next.js (apps/web) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOTRUE_URL=http://localhost:9999
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ─── FastAPI (apps/api) ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DATABASE_URL=postgresql+psycopg://postgres:postgres_dev@localhost:5432/archmentor
API_REDIS_URL=redis://localhost:6379/0
# Must match GOTRUE_JWT_SECRET — FastAPI verifies JWTs locally
API_JWT_SECRET=replace_with_openssl_rand_base64_48_output_here_xx
API_JWT_AUDIENCE=authenticated
# Must match GOTRUE_API_EXTERNAL_URL
API_JWT_ISSUER=http://localhost:9999
