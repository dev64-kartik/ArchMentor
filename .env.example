# ArchMentor — local dev environment
# Copy to .env and fill in secrets before running `./scripts/dev.sh`.
#
# ─── Paired values ──────────────────────────────────────────────────────
# The stack fails silently (401s, "invalid token", token-mint errors) if
# these pairs drift. When you replace a placeholder, update BOTH sides —
# a fresh `openssl rand -base64 48` per pair, copied to each member.
#
#   GOTRUE_JWT_SECRET       == API_JWT_SECRET
#   GOTRUE_API_EXTERNAL_URL == API_JWT_ISSUER
#   LIVEKIT_API_KEY         == API_LIVEKIT_API_KEY
#   LIVEKIT_API_SECRET      == API_LIVEKIT_API_SECRET
#   LIVEKIT_URL             == API_LIVEKIT_URL            == NEXT_PUBLIC_LIVEKIT_URL
#   API_AGENT_INGEST_TOKEN  == ARCHMENTOR_AGENT_INGEST_TOKEN

# ─── Postgres (shared) ──────────────────────────────────────────────────
# The superuser is pinned to `postgres` because GoTrue's migrations grant
# permissions to a `postgres` role. Renaming this breaks auth boot.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev
POSTGRES_DB=archmentor
POSTGRES_PORT=5432
AUTH_DB=auth
LANGFUSE_DB=langfuse

# ─── Supabase Auth (GoTrue) ─────────────────────────────────────────────
GOTRUE_PORT=9999
GOTRUE_API_EXTERNAL_URL=http://localhost:9999
SITE_URL=http://localhost:3000
# 32+ char random string. Generate: `openssl rand -base64 48`.
# PAIRED: must equal API_JWT_SECRET below — drift silently 401s every /me.
GOTRUE_JWT_SECRET=replace_with_openssl_rand_base64_48_output_here_xx

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── MinIO ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── LiveKit ────────────────────────────────────────────────────────────
# Both values MUST be replaced before running outside a single-machine
# dev loop. The defaults below contain the string `replace_with_` so the
# API's settings validator refuses to start with them in place.
# PAIRED: LIVEKIT_API_KEY    == API_LIVEKIT_API_KEY below.
# PAIRED: LIVEKIT_API_SECRET == API_LIVEKIT_API_SECRET below. Drift →
#   "invalid token: go-jose/go-jose: error in cryptographic primitive"
#   on the browser's LiveKit websocket handshake.
LIVEKIT_API_KEY=replace_with_openssl_rand_hex_16_output_here_xx
# 32+ char random string. Generate: `openssl rand -base64 48`
LIVEKIT_API_SECRET=replace_with_openssl_rand_base64_48_output_here_xx
LIVEKIT_PORT=7880
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_PORT=7882

# ─── Langfuse ───────────────────────────────────────────────────────────
LANGFUSE_PORT=3001
LANGFUSE_URL=http://localhost:3001
# 32+ char random strings
LANGFUSE_NEXTAUTH_SECRET=replace_with_openssl_rand_base64_48_output_here_xx
LANGFUSE_SALT=replace_with_openssl_rand_base64_48_output_here_xx
LANGFUSE_PUBLIC_KEY=pk-lf-dev-public-key
LANGFUSE_SECRET_KEY=sk-lf-dev-secret-key

# ─── Claude / Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Next.js (apps/web) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOTRUE_URL=http://localhost:9999
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ─── FastAPI (apps/api) ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DATABASE_URL=postgresql+psycopg://postgres:postgres_dev@localhost:5432/archmentor
API_REDIS_URL=redis://localhost:6379/0
# PAIRED: copy GOTRUE_JWT_SECRET verbatim. FastAPI verifies GoTrue JWTs
# with this; any drift silently 401s every /me request.
API_JWT_SECRET=replace_with_openssl_rand_base64_48_output_here_xx
API_JWT_AUDIENCE=authenticated
# PAIRED: copy GOTRUE_API_EXTERNAL_URL verbatim. PyJWT enforces the `iss`
# claim against this value.
API_JWT_ISSUER=http://localhost:9999
# LiveKit token minting.
# PAIRED: API_LIVEKIT_URL        == top-level LIVEKIT_URL / NEXT_PUBLIC_LIVEKIT_URL.
# PAIRED: API_LIVEKIT_API_KEY    == top-level LIVEKIT_API_KEY.
# PAIRED: API_LIVEKIT_API_SECRET == top-level LIVEKIT_API_SECRET.
# The API signs tokens with these; the LiveKit server verifies with its
# top-level pair. Drift → browser gets a token LiveKit refuses with
# "error in cryptographic primitive".
API_LIVEKIT_URL=ws://localhost:7880
API_LIVEKIT_API_KEY=replace_with_openssl_rand_hex_16_output_here_xx
API_LIVEKIT_API_SECRET=replace_with_openssl_rand_base64_48_output_here_xx
API_LIVEKIT_TOKEN_TTL_S=900
# Shared secret the agent presents on POST /sessions/{id}/events.
# Generate: `openssl rand -base64 48`.
# PAIRED: must equal ARCHMENTOR_AGENT_INGEST_TOKEN below. Drift →
# every ledger append fails 403 and session events are dropped.
API_AGENT_INGEST_TOKEN=replace_with_openssl_rand_base64_48_output_here_xx

# ─── Agent worker (apps/agent) ──────────────────────────────────────────
ARCHMENTOR_API_URL=http://localhost:8000
# PAIRED: copy API_AGENT_INGEST_TOKEN verbatim.
ARCHMENTOR_AGENT_INGEST_TOKEN=replace_with_openssl_rand_base64_48_output_here_xx
# The livekit-agents framework reads LIVEKIT_URL / LIVEKIT_API_KEY /
# LIVEKIT_API_SECRET by convention on worker boot.
# PAIRED: LIVEKIT_URL == API_LIVEKIT_URL == NEXT_PUBLIC_LIVEKIT_URL
# (already declared above as LIVEKIT_API_KEY / LIVEKIT_API_SECRET; the
# agent and API both talk to the same LiveKit server).
LIVEKIT_URL=ws://localhost:7880
# Model + device selection for local audio stack (macOS/Apple Silicon).
ARCHMENTOR_WHISPER_MODEL=large-v3
ARCHMENTOR_TTS_VOICE=af_bella
ARCHMENTOR_TTS_DEVICE=mps

# ─── Model caches (Kokoro weights, NLTK punkt) ──────────────────────────
# Kept local to the repo so the sandboxed harness can read+write them.
# Seed once via `uv run python scripts/warm_models.py`; dev.sh runs this
# automatically. With HF_HUB_OFFLINE=1 the agent never reaches the
# network after warm-up.
HF_HOME=./.model-cache/hf
NLTK_DATA=./.model-cache/nltk
HF_HUB_OFFLINE=1
